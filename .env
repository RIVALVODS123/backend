# Required
PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/urbanlegacy

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5500,https://tudominio.es

# Optional — Discord staff channel webhook
# Create one in: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
